{
  "name": "munea",
  "version": "1.0.4",
  "private": true,
  "description": "Munea iOS-first AI health-care companion app prototype.",
  "scripts": {
    "smoke": "powershell -ExecutionPolicy Bypass -File scripts/smoke.ps1",
    "smoke:no-api": "powershell -ExecutionPolicy Bypass -File scripts/smoke.ps1 -SkipApi",
    "smoke:auth": "powershell -ExecutionPolicy Bypass -File scripts/auth-gate-smoke.ps1",
    "smoke:admin": "powershell -ExecutionPolicy Bypass -File scripts/admin-smoke.ps1",
    "smoke:staging": "powershell -ExecutionPolicy Bypass -File scripts/staging-smoke.ps1",
    "smoke:staging:auth": "powershell -ExecutionPolicy Bypass -File scripts/staging-auth-smoke.ps1",
    "smoke:status": "powershell -ExecutionPolicy Bypass -File scripts/smoke-status.ps1",
    "test:agent-locks": "python scripts/test-agent-lock.py",
    "test:seo": "node scripts/test-app-site-seo.js",
    "test:ui-contracts": "node scripts/test-ui-contracts.js",
    "test:launch": "python engine/test_vitals_sync.py && python engine/test_thin_door.py && python engine/test_account_scope.py && python engine/test_request_scope.py && python engine/test_apple_store.py && python engine/test_free_signup_trial.py && python engine/test_family_invitation_access.py && python engine/test_subscription_expiry.py && python engine/test_localization.py && node scripts/test-store-verification.js && node scripts/test-health-connection.js && node scripts/test-native-auth.js && node scripts/test-development-profile.js && node scripts/test-release-settings.js && node scripts/test-ui-contracts.js",
    "release:check": "powershell -ExecutionPolicy Bypass -File scripts/release-check.ps1",
    "release:record": "powershell -ExecutionPolicy Bypass -File scripts/release-record.ps1",
    "mac:doctor": "bash scripts/mac-day-one-check.sh",
    "ai:doctor": "powershell -ExecutionPolicy Bypass -File scripts/ai-key-doctor.ps1 -AllowMissing",
    "ai:doctor:live": "powershell -ExecutionPolicy Bypass -File scripts/ai-key-doctor.ps1",
    "cloudrun:deploy:staging": "powershell -ExecutionPolicy Bypass -File scripts/cloud-run-deploy-staging.ps1",
    "cloudrun:readiness": "powershell -ExecutionPolicy Bypass -File scripts/cloud-run-status.ps1 -Readiness",
    "cloudrun:status": "powershell -ExecutionPolicy Bypass -File scripts/cloud-run-status.ps1",
    "supabase:doctor": "powershell -ExecutionPolicy Bypass -File scripts/supabase-doctor.ps1 --allow-missing",
    "supabase:doctor:live": "powershell -ExecutionPolicy Bypass -File scripts/supabase-doctor.ps1 --live",
    "supabase:bundle:missing": "powershell -ExecutionPolicy Bypass -File scripts/supabase-bundle-missing.ps1",
    "cap:doctor": "npx cap doctor",
    "cap:sync": "npx cap sync",
    "cap:add:ios": "npx cap add ios",
    "cap:open:ios": "npx cap open ios",
    "xcode:check": "bash scripts/xcode-native-check.sh",
    "ios:build": "bash scripts/ios-simulator-build.sh",
    "ios:archive": "bash scripts/ios-archive.sh",
    "ios:export": "bash scripts/ios-export-app-store.sh",
    "ios:dev-profile": "node scripts/enable-ios-development-profile.mjs",
    "ios:package": "npm run ios:archive && npm run ios:export"
  },
  "dependencies": {
    "@capacitor/app": "8.1.0",
    "@capacitor/browser": "8.0.3",
    "@capacitor/core": "^8.4.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@capacitor/ios": "^8.4.1"
  }
}
