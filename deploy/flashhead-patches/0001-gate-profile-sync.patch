+# ---------------------------------------------------------------------------
+# Munea patch (calcifer 2026-07-23, N-way batching surgery phase 1 / option B).
+# Source: deploy/flashhead-patches/0001-gate-profile-sync.patch in the Munea
+# repo. Design doc: docs/research/合批手術-設計方案-2026-07-23.md section 1.2
+# (item 3).
+#
+# generate() below calls a CUDA device-sync barrier 8 times (about 14
+# invocations per chunk once the 4-step denoise loop is counted) purely to
+# bracket wall-clock print() timing lines. None of them are required for
+# correctness -- the denoise/VAE data-dependency chain is already ordered by
+# the CUDA stream itself. The barrier blocks until every stream on the
+# current CUDA context has drained, not just the calling thread's own work.
+# Munea's N-slot server runs all slots as Python threads inside ONE process
+# (one CUDA context), so each of these barriers also waits on whatever the
+# OTHER slots queued -- this is the main root cause of the "3 slots run
+# slower than 3x" behaviour seen in the 2026-07-23 concurrency benchmark.
+#
+# PROFILE_SYNC controls this barrier and follows the same external-override
+# convention already used for COMPILE_MODEL / COMPILE_VAE above: it defaults
+# to True here (pre-patch behaviour, byte-for-byte -- the barrier still fires
+# every call, timing prints stay accurate) and Munea's flashhead_server.py
+# sets it from MUNEA_FH_PROFILE_SYNC after importing this module, exactly
+# like it already does for COMPILE_MODEL/COMPILE_VAE via MUNEA_FH_COMPILE.
+# When set to False, the print() lines still run but no longer reflect a
+# GPU-drained wall time.
+# ---------------------------------------------------------------------------
+PROFILE_SYNC = True
+
+
+def _profile_sync():
+    if PROFILE_SYNC:
+        torch.cuda.synchronize()
+
+
