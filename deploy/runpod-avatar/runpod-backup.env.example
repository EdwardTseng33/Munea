# RunPod API and private production template
RUNPOD_API_KEY=
MUNEA_RUNPOD_TEMPLATE_ID=

# Fail-safe first: switch to active only after the 0->1->0 production drill.
MUNEA_RUNPOD_AUTOMATION_MODE=observe
MUNEA_RUNPOD_GPU_TYPES=NVIDIA GeForce RTX 4090,NVIDIA RTX 6000 Ada Generation,NVIDIA GeForce RTX 5090
MUNEA_RUNPOD_DATA_CENTERS=AP-JP-1
MUNEA_RUNPOD_SLOTS=2
MUNEA_RUNPOD_MAX_PODS=14
MUNEA_RUNPOD_MAX_SCALE_UP_PER_CYCLE=4
MUNEA_TARGET_CONCURRENT_CALLS=30
MUNEA_RUNPOD_SCALE_UP_UTILIZATION=0.80
MUNEA_RUNPOD_FAILURE_THRESHOLD=3
MUNEA_RUNPOD_IDLE_SECONDS=900
MUNEA_RUNPOD_COOLDOWN_SECONDS=300
MUNEA_RUNPOD_SCALE_UP_COOLDOWN_SECONDS=15
MUNEA_RUNPOD_SCALE_DOWN_ACTION=stop

# Call Control / Gateway control-plane credentials
MUNEA_GATEWAY_URL=https://replace-with-call-control.example
MUNEA_GATEWAY_ADMIN_KEY=
MUNEA_GATEWAY_QUEUE_MAX_DEPTH=30
MUNEA_AVATAR_APP_KEY=
