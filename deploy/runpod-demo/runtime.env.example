# Values only for the isolated B2B Demo lane. Do not put App keys here.
MUNEA_FH_LANE=demo
MUNEA_FACE_PORT=8188
MUNEA_FH_FRAME_SIZE=768
MUNEA_FH_SLOTS=1
MUNEA_FH_DEFAULT_CHAR=a05d
MUNEA_FH_ALLOWED_CHARS=a05d,a06d
MUNEA_FH_DEMO_720P_CHAR_A05D=/workspace/munea-demo/assets-720p/char-a05B-demo-square-768.png
MUNEA_FH_DEMO_720P_CHAR_A06D=/workspace/munea-demo/assets-720p/char-a06B-demo-square-768.png
MUNEA_FH_AUDIO_PREBUFFER_S=0.5
MUNEA_FH_OPENING_PREBUFFER_S=1.0
MUNEA_FH_COMPILE=0
MUNEA_FH_SHARPEN=0
MUNEA_FH_MODEL_ROOT=/workspace/munea-models
MUNEA_FH_CKPT_DIR=/workspace/munea-models/soulx-flashhead-1.3b
MUNEA_FH_WAV2VEC_DIR=/workspace/munea-models/wav2vec2-base-960h
MUNEA_FH_REPO=/workspace/munea-install/src/SoulX-FlashHead
MUNEA_PYTHON_BIN=/workspace/munea-venv/bin/python
MUNEA_WORKER_CORS_ORIGINS=https://munea-b2b.vercel.app,http://localhost:3000,http://localhost:4173
MUNEA_ALLOW_LEGACY_APP_KEY=0
MUNEA_DEMO_TOKEN_TTL=300
