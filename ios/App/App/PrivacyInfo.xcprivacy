<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  沐寧 Munea · Privacy Manifest
  對齊基準：App Store Connect「App 隱私權」問卷（2026-07-16 填答），15 種資料類型逐項一致。
  依據文件：docs/App-Privacy-問卷填答表-2026-07-16.md（每項附程式碼證據）
  ⚠ 修改本檔時務必同步更新 App Store Connect 問卷與上述文件，三者不可分歧。
-->
<plist version="1.0">
<dict>
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>

	<!-- Required Reason API：NotifyPlugin.swift 以 UserDefaults 保存推播設定與裝置代碼。
	     CA92.1 = 僅存取本 App 自身的 user defaults。 -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<key>NSPrivacyAccessedAPIType</key><string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key><array><string>CA92.1</string></array>
		</dict>
	</array>

	<key>NSPrivacyCollectedDataTypes</key>
	<array>
		<!-- 1. 姓名／暱稱、家人照護圈成員稱呼 -->
		<dict>
			<key>NSPrivacyCollectedDataType</key><string>NSPrivacyCollectedDataTypeName</string>
			<key>NSPrivacyCollectedDataTypeLinked</key><true/>
			<key>NSPrivacyCollectedDataTypeTracking</key><false/>
			<key>NSPrivacyCollectedDataTypePurposes</key><array><string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string></array>
		</dict>
		<!-- 2. 帳號 email -->
		<dict>
			<key>NSPrivacyCollectedDataType</key><string>NSPrivacyCollectedDataTypeEmailAddress</string>
			<key>NSPrivacyCollectedDataTypeLinked</key><true/>
			<key>NSPrivacyCollectedDataTypeTracking</key><false/>
			<key>NSPrivacyCollectedDataTypePurposes</key><array><string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string></array>
		</dict>
		<!-- 3. 健康：心率／血壓／血氧／睡眠＋用藥提醒（HealthPlugin → /family/state） -->
		<dict>
			<key>NSPrivacyCollectedDataType</key><string>NSPrivacyCollectedDataTypeHealth</string>
			<key>NSPrivacyCollectedDataTypeLinked</key><true/>
			<key>NSPrivacyCollectedDataTypeTracking</key><false/>
			<key>NSPrivacyCollectedDataTypePurposes</key><array><string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string><string>NSPrivacyCollectedDataTypePurposeProductPersonalization</string></array>
		</dict>
		<!-- 4. 健身：步數 -->
		<dict>
			<key>NSPrivacyCollectedDataType</key><string>NSPrivacyCollectedDataTypeFitness</string>
			<key>NSPrivacyCollectedDataTypeLinked</key><true/>
			<key>NSPrivacyCollectedDataTypeTracking</key><false/>
			<key>NSPrivacyCollectedDataTypePurposes</key><array><string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string><string>NSPrivacyCollectedDataTypePurposeProductPersonalization</string></array>
		</dict>
		<!-- 5. 粗略位置：使用者自填縣市 → open-meteo 查天氣。不存我方伺服器、不帶識別碼 → 不與身分連結。
		     （2026-07-09 已移除 GPS 精確定位備援；Info.plist 亦無任何定位權限說明字串。） -->
		<dict>
			<key>NSPrivacyCollectedDataType</key><string>NSPrivacyCollectedDataTypeCoarseLocation</string>
			<key>NSPrivacyCollectedDataTypeLinked</key><false/>
			<key>NSPrivacyCollectedDataTypeTracking</key><false/>
			<key>NSPrivacyCollectedDataTypePurposes</key><array><string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string></array>
		</dict>
		<!-- 6. 電子郵件或訊息：家人傳話（sender／recipient／content） -->
		<dict>
			<key>NSPrivacyCollectedDataType</key><string>NSPrivacyCollectedDataTypeEmailsOrTextMessages</string>
			<key>NSPrivacyCollectedDataTypeLinked</key><true/>
			<key>NSPrivacyCollectedDataTypeTracking</key><false/>
			<key>NSPrivacyCollectedDataTypePurposes</key><array><string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string></array>
		</dict>
		<!-- 7. 照片或影片：意見回饋附圖（用藥照片自本次修正起只留本機、不上雲；個人頭像本就只在本機） -->
		<dict>
			<key>NSPrivacyCollectedDataType</key><string>NSPrivacyCollectedDataTypePhotosorVideos</string>
			<key>NSPrivacyCollectedDataTypeLinked</key><true/>
			<key>NSPrivacyCollectedDataTypeTracking</key><false/>
			<key>NSPrivacyCollectedDataTypePurposes</key><array><string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string></array>
		</dict>
		<!-- 8. 音訊資料：通話語音（僅用於理解對話內容，不用於聲紋辨識或身份識別） -->
		<dict>
			<key>NSPrivacyCollectedDataType</key><string>NSPrivacyCollectedDataTypeAudioData</string>
			<key>NSPrivacyCollectedDataTypeLinked</key><true/>
			<key>NSPrivacyCollectedDataTypeTracking</key><false/>
			<key>NSPrivacyCollectedDataTypePurposes</key><array><string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string><string>NSPrivacyCollectedDataTypePurposeProductPersonalization</string></array>
		</dict>
		<!-- 9. 客戶支援：意見回饋文字內容 -->
		<dict>
			<key>NSPrivacyCollectedDataType</key><string>NSPrivacyCollectedDataTypeCustomerSupport</string>
			<key>NSPrivacyCollectedDataTypeLinked</key><true/>
			<key>NSPrivacyCollectedDataTypeTracking</key><false/>
			<key>NSPrivacyCollectedDataTypePurposes</key><array><string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string></array>
		</dict>
		<!-- 10. 其他使用者內容：聊天文字、AI 對話摘要、家人留言／塗鴉、心情紀錄 -->
		<dict>
			<key>NSPrivacyCollectedDataType</key><string>NSPrivacyCollectedDataTypeOtherUserContent</string>
			<key>NSPrivacyCollectedDataTypeLinked</key><true/>
			<key>NSPrivacyCollectedDataTypeTracking</key><false/>
			<key>NSPrivacyCollectedDataTypePurposes</key><array><string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string><string>NSPrivacyCollectedDataTypePurposeProductPersonalization</string></array>
		</dict>
		<!-- 11. 使用者識別碼：account_id／personId（後端會掛在產品事件上） -->
		<dict>
			<key>NSPrivacyCollectedDataType</key><string>NSPrivacyCollectedDataTypeUserID</string>
			<key>NSPrivacyCollectedDataTypeLinked</key><true/>
			<key>NSPrivacyCollectedDataTypeTracking</key><false/>
			<key>NSPrivacyCollectedDataTypePurposes</key><array><string>NSPrivacyCollectedDataTypePurposeAnalytics</string><string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string></array>
		</dict>
		<!-- 12. 裝置識別碼：推播通知裝置代碼（無 IDFA、無廣告識別碼） -->
		<dict>
			<key>NSPrivacyCollectedDataType</key><string>NSPrivacyCollectedDataTypeDeviceID</string>
			<key>NSPrivacyCollectedDataTypeLinked</key><true/>
			<key>NSPrivacyCollectedDataTypeTracking</key><false/>
			<key>NSPrivacyCollectedDataTypePurposes</key><array><string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string></array>
		</dict>
		<!-- 13. 購買記錄：訂閱方案狀態、點數餘額（卡號由 Apple 處理，我方不取得） -->
		<dict>
			<key>NSPrivacyCollectedDataType</key><string>NSPrivacyCollectedDataTypePurchaseHistory</string>
			<key>NSPrivacyCollectedDataTypeLinked</key><true/>
			<key>NSPrivacyCollectedDataTypeTracking</key><false/>
			<key>NSPrivacyCollectedDataTypePurposes</key><array><string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string></array>
		</dict>
		<!-- 14. 產品互動：產品事件埋點（/product-event） -->
		<dict>
			<key>NSPrivacyCollectedDataType</key><string>NSPrivacyCollectedDataTypeProductInteraction</string>
			<key>NSPrivacyCollectedDataTypeLinked</key><true/>
			<key>NSPrivacyCollectedDataTypeTracking</key><false/>
			<key>NSPrivacyCollectedDataTypePurposes</key><array><string>NSPrivacyCollectedDataTypePurposeAnalytics</string><string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string></array>
		</dict>
		<!-- 15. 效能資料：通話診斷（各階段耗時、失敗碼）。無當機回報 SDK → 不宣告 Crash Data -->
		<dict>
			<key>NSPrivacyCollectedDataType</key><string>NSPrivacyCollectedDataTypePerformanceData</string>
			<key>NSPrivacyCollectedDataTypeLinked</key><true/>
			<key>NSPrivacyCollectedDataTypeTracking</key><false/>
			<key>NSPrivacyCollectedDataTypePurposes</key><array><string>NSPrivacyCollectedDataTypePurposeAnalytics</string><string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string></array>
		</dict>
	</array>
</dict>
</plist>
